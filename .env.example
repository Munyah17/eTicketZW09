# ==============================================================
#  E-TicketsZW — Environment Variables Template
# ==============================================================
#  HOW TO USE
#  1. Copy this file:  cp .env.example .env.local
#  2. Fill in every value marked  ← FILL IN
#  3. Never commit .env.local  (it is already in .gitignore)
# ==============================================================


# ── APP ────────────────────────────────────────────────────────
# Your production domain.  Local dev → http://localhost:3000
NEXT_PUBLIC_BASE_URL=https://eticket.co.zw                        # ← FILL IN


# ── SUPABASE ───────────────────────────────────────────────────
# supabase.com → your project → Settings → API

# Project URL  (safe to expose — used by browser & server)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co  # ← FILL IN

# Anon / Public key  (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx  # ← FILL IN

# Service Role key  ⚠️  NEVER expose to the browser — server-side only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx       # ← FILL IN

# JWT Secret  (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-here              # ← FILL IN

# Project Reference ID  (the slug before .supabase.co)
# Used by the Supabase CLI and MCP server
SUPABASE_PROJECT_REF=xxxxxxxxxxxxxxxxxxxx                          # ← FILL IN

# Database password  (set when you created the project)
# Used by Supabase CLI for migrations:  supabase db push
SUPABASE_DB_PASSWORD=your-database-password-here                  # ← FILL IN


# ── STRIPE ─────────────────────────────────────────────────────
# stripe.com → Developers → API Keys

# Secret key  ⚠️  NEVER expose to the browser — server-side only
# Format: sk_live_... (production)  or  sk_test_... (local dev)
STRIPE_SECRET_KEY=your_stripe_secret_key_here                     # ← FILL IN

# Publishable key  (safe to expose to the browser)
# Format: pk_live_... (production)  or  pk_test_... (local dev)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here  # ← FILL IN

# Webhook signing secret
# Production:  Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# Local dev:   run  stripe listen --forward-to localhost:3000/api/payments/webhook/stripe
#              then paste the  whsec_  key printed in the terminal
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here             # ← FILL IN


# ── PAYNOW ─────────────────────────────────────────────────────
# developers.paynow.co.zw → Integrations → your integration

PAYNOW_INTEGRATION_ID=00000                                        # ← FILL IN
PAYNOW_INTEGRATION_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx       # ← FILL IN


# ── ECOCASH INSTANT PAYMENT (EIP) ───────────────────────────────
# developers.ecocash.co.zw → your app → Sandbox Credentials
# Direct-charge API: sends a USSD PIN prompt straight to the buyer's phone
# (no redirect page, unlike Paynow/Stripe).

# Sandbox: https://developers.ecocash.co.zw/sandbox/payment/v1
# Production base URL is issued after EcoCash approves your go-live test script.
ECOCASH_EIP_BASE_URL=https://developers.ecocash.co.zw/sandbox/payment/v1  # ← FILL IN

ECOCASH_EIP_USERNAME=sbx_xxxxxxxxxxxx                              # ← FILL IN
ECOCASH_EIP_PASSWORD=xxxxxxxxxxxxxxxxxxxx                          # ← FILL IN
ECOCASH_MERCHANT_CODE=000000                                       # ← FILL IN
ECOCASH_MERCHANT_PIN=0000                                          # ← FILL IN
ECOCASH_MERCHANT_NUMBER=77xxxxxxx                                  # ← FILL IN
ECOCASH_TERMINAL_ID=WEB01                                          # ← any non-blank string works in sandbox


# ── EMAIL  (optional — transactional emails) ───────────────────
# Resend (recommended): resend.com → API Keys
# The eticket.co.zw domain must be verified in Resend (Domains → Add Domain,
# then add the SPF/DKIM DNS records Resend gives you) before this address will
# actually deliver — otherwise Resend silently restricts sending to your own
# account email only.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx           # ← FILL IN (if using)
# EMAIL_FROM=E-TicketsZW <pay@eticket.co.zw>                       # ← FILL IN (if using)


# ── WHATSAPP  (optional — ticket delivery via WhatsApp) ────────
# Meta WhatsApp Business Cloud API: developers.facebook.com → your app
# → WhatsApp → API Setup. Tickets are pushed to the buyer's WhatsApp
# right after email; without these, delivery gracefully falls back to
# email only.
# WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxx              # ← FILL IN (if using)
# WHATSAPP_PHONE_NUMBER_ID=123456789012345                           # ← FILL IN (if using)
# Approved message template name for business-initiated sends
# (required by Meta outside the 24h customer-service window).
# Template should have an IMAGE header + 2 body params: {{1}} buyer
# name, {{2}} event title.
# WHATSAPP_TICKET_TEMPLATE=ticket_delivery                           # ← FILL IN (if using)


# ── GROQ  (optional — AI Data Analytics business insights) ─────
# console.groq.com → API Keys → Create API Key. Free tier, no card
# required. Powers the AI-written narrative on Super Admin's
# "AI Data Analytics" page — the page still shows all real computed
# stats/charts without this, just skips the AI summary.
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx     # ← FILL IN (if using)


# ── VERCEL / ANALYTICS (auto-set by Vercel, no action needed) ──
# VERCEL_URL is injected automatically during Vercel builds.
# NEXT_PUBLIC_VERCEL_URL is also available if needed.


# ==============================================================
#  SUPABASE MCP SERVER  (Claude Code only — NOT a Next.js var)
# ==============================================================
#  This token is NOT placed here.  It goes into Claude Code's
#  settings so Claude can build the Supabase backend directly.
#
#  Where to get it:
#    supabase.com → Account (top-right avatar) → Access Tokens
#    → Generate new token  →  name it "Claude Code MCP"
#
#  Where it goes (Claude Code will configure this for you once
#  you paste the token):
#    ~/.claude/settings.json  (global, never committed)
#    key: mcpServers.supabase.env.SUPABASE_ACCESS_TOKEN
# ==============================================================
