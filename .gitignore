# v0 sandbox internal files
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
.snowflake/
.v0-trash/
.vercel/
next.user-config.*

# Environment variables — all real-key files are blocked
# .env.example is the ONLY env file that should be committed
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env*.local
# Extra safety net — catch any ad-hoc copies
*.env.bak
*.env.backup

# MCP config — contains real access tokens, never commit
.mcp.json

# Common ignores
node_modules
.next/
.DS_Store
.vercel
